#################################################################
# Windows generic sample
#
# This sample uses the built-in Windows composition and points to
# a resource file where users can register delegate-based capability
# and service wrappers.
#################################################################

Mode = Spy

SUTConnector = COMMAND_LINE
SUTConnectorValue = c:\\windows\\system32\\notepad.exe
SUTProcesses =
AccessBridgeEnabled = false

Sequences = 8
SequenceLength = 10

CompositionProfile = windows_composition
CustomCompositionResource = ./settings/windows_generic/composition.properties
CustomPoliciesResource = ./settings/windows_generic/policies.properties

ClickFilter = .*[sS]istema.*|.*[sS]ystem.*|.*[cC]errar.*|.*[cC]lose.*|.*[sS]alir.*|.*[eE]xit.*|.*[mM]inimizar.*|.*[mM]inimi[zs]e.*|.*[gG]uardar.*|.*[sS]ave.*|.*[iI]mprimir.*|.*[pP]rint.*
TagsToFilter = Title
ProcessesToKillDuringTest =

IgnoreDuplicatedVerdicts = false
SuspiciousTags = .*[eE]rror.*|.*[eE]xcepti[o?]n.*
TagsForSuspiciousOracle = Title

ProcessListenerEnabled = false
SuspiciousProcessOutput = .*[eE]rror.*|.*[eE]xcep[ct]i[o?]n.*
ProcessLogs = .*.*

LogOracleEnabled = false
LogOracleRegex = .*([Ee]xception|[Ee]rror).*
LogOracleCommands =
LogOracleFiles = test_print_exception.log;../../testar/bin/test_print_error.log

ActionDuration = 0.1
TimeToWaitAfterAction = 0.1
StartupTime = 10.0
MaxTime = 3.1536E7

ApplicationName = Windows Generic
ApplicationVersion =

StateModelEnabled = false
DataStore =
DataStoreType = remote
DataStoreServer =
DataStoreDirectory =
DataStoreDB =
DataStoreUser =
DataStorePassword =
DataStoreMode = none
ActionSelectionAlgorithm = random
StateModelStoreWidgets = false
ResetDataStore = false

AbstractStateAttributes = WidgetControlType

ProtocolSpecificSetting_1 =
ProtocolSpecificSetting_2 =
ProtocolSpecificSetting_3 =
ProtocolSpecificSetting_4 =
ProtocolSpecificSetting_5 =

ReportInHTML = true
ReportInPlainText = true
ExtendedOracles =

ShowVisualSettingsDialogOnStartup = true
ForceForeground = true
VisualizeActions = false
LogLevel = 1
OnlySaveFaultySequences = false
StopGenerationOnFault = true
TimeToFreeze = 30.0
UseSystemActions = false
RefreshSpyCanvas = 1.0
MaxReward = 9999999
Discount = .95
CreateWidgetInfoJsonFile = true
OutputDir = ./output
TempDir = ./output/temp
