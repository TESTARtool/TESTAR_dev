#################################################################
# Android generic sample
#
# This sample uses the built-in Android composition and points to
# a resource file where users can register delegate-based capability
# and service wrappers.
#################################################################

Mode = Spy

SUTConnector = ANDROID_APPIUM
SUTConnectorValue =
SUTProcesses =

Sequences = 5
SequenceLength = 10

CompositionProfile = android_composition
CustomCompositionResource = ./settings/android_generic/composition.properties
CustomPoliciesResource = ./settings/android_generic/policies.properties

ClickFilter = .*Graphics.*
TagsToFilter = AndroidAccessibilityId;AndroidText
ProcessesToKillDuringTest =

IgnoreDuplicatedVerdicts = false
SuspiciousTags = .*[eE]rror.*|.*[eE]xcepti[o?]n.*
TagsForSuspiciousOracle = Title

ProcessListenerEnabled = false
SuspiciousProcessOutput = .*[eE]rror.*|.*[eE]xcep[ct]i[o?]n.*
ProcessLogs = .*.*

LogOracleEnabled = false
LogOracleRegex = .*([Ee]xception|[Ee]rror).*
LogOracleCommands =
LogOracleFiles =

ActionDuration = 0.1
TimeToWaitAfterAction = 2.0
StartupTime = 2.0
MaxTime = 3.1536E7

ApplicationName = Android Generic
ApplicationVersion =

StateModelEnabled = false
DataStore =
DataStoreType = remote
DataStoreServer =
DataStoreDirectory =
DataStoreDB =
DataStoreUser =
DataStorePassword =
DataStoreMode = none
ActionSelectionAlgorithm = random
StateModelStoreWidgets = false
ResetDataStore = false

AbstractStateAttributes = WidgetControlType
StateObservationMode = FULL_STATE

AppiumPlatformName = Android
AppiumIsApkInstalled = false
AppiumApp = suts/ApiDemos-debug.apk
AppiumAppPackage =
AppiumAppActivity =
AppiumIsEmulatorDocker = false
AppiumIpAddress =
AppiumDeviceName = Android Emulator
AppiumAutomationName = UiAutomator2
AppiumNewCommandTimeout = 600
AppiumAutoGrantPermissions = false
AppiumAllowInvisibleElements = false
AppiumIgnoreHiddenApiPolicyError = false
AppiumAdbExecTimeout = 120000
AppiumUiautomator2ServerInstallTimeout = 120000
AppiumUiautomator2ServerLaunchTimeout = 120000
AndroidClickableClasses =
AndroidTypeableClasses =

ProtocolSpecificSetting_1 =
ProtocolSpecificSetting_2 =
ProtocolSpecificSetting_3 =
ProtocolSpecificSetting_4 =
ProtocolSpecificSetting_5 =

ReportInHTML = true
ReportInPlainText = true
ExtendedOracles =

ShowVisualSettingsDialogOnStartup = true
ForceForeground = true
VisualizeActions = false
LogLevel = 1
OnlySaveFaultySequences = false
StopGenerationOnFault = true
TimeToFreeze = 30.0
UseSystemActions = false
RefreshSpyCanvas = 1.0
MaxReward = 9999999
Discount = .95
CreateWidgetInfoJsonFile = false
OutputDir = ./output
TempDir = ./output/temp
