<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="org.testar.settings.backend">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd-HH:mm:ss.SSS} %msg%n"/>
            <Filters>
                <!-- Allow only messages with level DEBUG and above to be printed to the console -->
                <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </Console>
        <RollingFile name="RollingFile" fileName="index.log" filePattern="../logs/index-%d{MM-dd-yyyy}.log.gz"
                     ignoreExceptions="false">
            <PatternLayout pattern="%d{yyyy-MM-dd-HH:mm:ss.SSS} %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB" />
            </Policies>
        </RollingFile>
        <WebSocket name="WebSocketAppender">
            <PatternLayout pattern="%d{yyyy-MM-dd-HH:mm:ss.SSS} %msg%n"/>
            <Filters>
                <!-- Only send INFO and above to websocket to avoid overwhelming clients -->
                <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </WebSocket>
    </Appenders>
    <Loggers>
        <Logger name="io.netty" level="off"/> <!-- Ignore ugly warning https://github.com/netty/netty/issues/7817 -->
        <Root level="ALL">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
            <AppenderRef ref="WebSocketAppender"/>
        </Root>
    </Loggers>
</Configuration>
